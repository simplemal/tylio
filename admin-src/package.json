{
  "name": "tylio-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check-i18n && vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,json,md}\"",
    "type-check": "vue-tsc --noEmit",
    "check": "npm run lint && npm run type-check && npm run format:check",
    "check-i18n": "node scripts/check-i18n-syntax.mjs"
  },
  "dependencies": {
    "@vueuse/core": "^11.2.0",
    "iconify-icon": "^2.1.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.31.0",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
