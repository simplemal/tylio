APP_ENV=production
APP_DEBUG=false
APP_NAME=tylio
# Canonical public URL of the site. Used for Secure cookies + absolute URLs.
APP_URL=https://example.com
# Key for internal HMAC. Generate with:
#   php -r 'echo bin2hex(random_bytes(32));'
APP_KEY=

ADMIN_PATH=/admin

# SQLite database (path relative to project root)
DATABASE_PATH=data/db.sqlite

# Session lifetime in seconds. The session NAME (cookie name) and the
# storage backend are hardcoded — sessions live in the `sessions` table
# in the SQLite database (DATABASE_PATH).
SESSION_LIFETIME=86400

# Trusted proxy IPs (CSV, CIDR). Default: Cloudflare ranges.
TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

# Login rate-limit
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# Retention windows (in days) consumed by `php scripts/cleanup.php`.
# Defaults are conservative and configurable per deploy.
LOGIN_RETENTION_DAYS=7
AUDIT_RETENTION_DAYS=90
VISITS_RETENTION_DAYS=365

# Upload limits
UPLOAD_MAX_BYTES=10485760
# SVG NOT allowed (XSS risk via inline <script>). Re-enable only via a sanitizer.
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,image/gif

# Outbound email (OPTIONAL, Symfony Mailer DSN). Empty = email disabled.
# Example: smtps://user%40example.com:PASSWORD@smtps.provider.com:465
MAIL_DSN=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=tylio
# Optional pepper for hashing email-verification codes. When unset, the
# service falls back to a deterministic derivative of APP_KEY (still
# safe but less defense-in-depth on DB exfiltration). Generate with:
#   php -r 'echo bin2hex(random_bytes(32));'
EMAIL_VERIFICATION_PEPPER=
